pipeline {
  agent any
  environment {
    S3_BUCKET = 'demo-apk-storage'
    APK_PATH = 'android/app/build/outputs/apk/release/app-release.apk'
    ANDROID_HOME = '/var/lib/jenkins/Android/Sdk'  
    PATH = "${ANDROID_HOME}/platform-tools:${ANDROID_HOME}/tools:${env.PATH}"
  }

  stages {
    stage('1. Checkout') {
      steps {
        checkout scmGit(
          branches: [[name: '*/main']],
          extensions: [],
          userRemoteConfigs: [[url: 'https://github.com/SubhuJaat07/ophelia-games-app.git']]
        )
      }
    }

    stage('2. npm install') {
      steps {
        sh "rm -rf package-lock.json node_modules"
        sh "npm install"
      }
    }

    stage('3. prebuild') {
      steps {
        sh "rm -rf android ios"
        sh "npx expo install --fix"
        sh "npx expo prebuild --platform android"
      }
    }

    stage('4. build apk file') {
      steps {
        sh '''
          # Create local.properties with correct SDK path
          echo "sdk.dir=/var/lib/jenkins/Android/Sdk" > android/local.properties

          # Verify SDK exists
          echo "Checking SDK path..."
          ls /var/lib/jenkins/Android/Sdk || echo "SDK NOT FOUND!"

          cd android
          chmod +x gradlew
          ./gradlew clean assembleRelease --stacktrace
        '''
      }
    }

    stage('5. Upload APK to S3') {
      steps {
        withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws_apk_cred_demo']]) {
          sh """
            aws s3 cp ${APK_PATH} s3://${S3_BUCKET}/releases/app-release${BUILD_NUMBER}.apk
            aws s3 cp ${APK_PATH} s3://${S3_BUCKET}/latest/app-release.apk
          """
        }
      }
    }
  }
}
